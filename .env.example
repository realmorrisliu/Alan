# alan release configuration
# Copy this file to `.env`, then fill in your local signing and notarization values.

# Local install: `just install` uses only the Developer ID identity below.
# Public release: `just release-check` validates notarization, then `just release`
# builds, signs, notarizes, staples, and archives.

# Must exactly match one Developer ID Application common name from:
#   security find-identity -v -p codesigning
ALAN_DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (TEAMID)"

# Notary keychain profile used by `just release`.
# If this profile does not already exist, `just release-check` creates it from
# the Apple ID credentials below.
ALAN_NOTARY_KEYCHAIN_PROFILE="alan-notary"

# Apple ID credentials for automatically creating/updating the notary keychain profile.
# APPLE_APP_SPECIFIC_PASSWORD is generated at appleid.apple.com and is not your
# Apple ID login password.
APPLE_ID="your-apple-id@example.com"
APPLE_TEAM_ID="TEAMID"
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
