# Self-eval promotion threshold config (versioned)
THRESHOLD_VERSION="v1"

# Candidate absolute quality floor
MIN_CANDIDATE_PASS_RATE=95

# Candidate can be at most this many points lower than baseline
MAX_ALLOWED_PASS_RATE_DROP=0

# Candidate cannot introduce extra governance boundary violations
MAX_BOUNDARY_VIOLATIONS_DELTA=0

# Candidate recovery-related scenarios must stay healthy
MIN_RECOVERY_SUCCESS_RATE=95

# Candidate runtime overhead protection (% increase vs baseline)
MAX_DURATION_INCREASE_PERCENT=50
