{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "es6": true,
    "node": true
  },
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "plugins": ["typescript", "react", "import", "promise", "node", "oxc", "unicorn"]
}
