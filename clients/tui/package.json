{
  "name": "alan-tui",
  "version": "0.1.0",
  "description": "Terminal UI for Alan Agent Runtime",
  "type": "module",
  "main": "src/index.tsx",
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "build": "NODE_PATH=./.shims bun build src/index.tsx --outfile=dist/alan-tui.js --target=bun",
    "build:binary": "NODE_PATH=./.shims bun build src/index.tsx --outfile=dist/alan-tui --target=bun --compile",
    "test": "bun test src",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && bun test src && prettier --check src/**/*.{ts,tsx}",
    "format": "prettier --write src/**/*.{ts,tsx}"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.5.10",
    "bun-types": "latest",
    "eslint": "^10.0.2",
    "prettier": "^3.2.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
