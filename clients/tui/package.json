{
  "name": "alan-tui",
  "version": "0.1.0",
  "description": "Terminal UI for Alan Agent Runtime",
  "type": "module",
  "main": "src/index.tsx",
  "bin": {
    "alan": "./bin/alan"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "build": "bun build src/index.tsx --outdir=dist",
    "build:binary": "./scripts/build.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.{ts,tsx}",
    "format": "prettier --write src/**/*.{ts,tsx}"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.5.10",
    "bun-types": "latest",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
